# ─────────────────────────────────────────────────────────────────────────────
# KARSON — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/karson_db?schema=public

# For Prisma connection pooling in production (use Prisma Accelerate or pgBouncer)
# DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-super-secret-key-at-least-32-chars-long
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Email (Resend — recommended for production) ───────────────────────────────
# Get API key at: https://resend.com
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=KARSON <noreply@karson.ai>
EMAIL_ADMIN=admin@karson.ai

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Cloudinary (Image uploads) ────────────────────────────────────────────────
# Get at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── SEO ───────────────────────────────────────────────────────────────────────
# Get from: https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=your-google-verification-code

# ── Analytics ─────────────────────────────────────────────────────────────────
# Vercel Analytics is enabled automatically on Vercel
# For self-hosted, add your Plausible/PostHog keys here
NEXT_PUBLIC_ANALYTICS_ID=

# ── Redis (Optional — for production rate limiting & caching) ─────────────────
# Upstash Redis: https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-char-hex-encryption-key
